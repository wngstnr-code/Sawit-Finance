# Sawit Finance — frontend environment variables
#
# Copy this file to `.env.local` (git-ignored) and fill in real values if you
# have them. None of these are required to run the app locally — every API
# route degrades to bundled snapshot/demo data when a binary or key is
# missing (see frontend/README.md → "Live vs. snapshot data").
#
# NEVER commit real secrets. This file only contains placeholders.

# ---------------------------------------------------------------------------
# Client-exposed (NEXT_PUBLIC_*) — bundled into the browser JS, not secret.
# ---------------------------------------------------------------------------

# CSPR.click wallet app id (get one from the CSPR.click dashboard).
# Optional — falls back to a shared "csprclick-template" placeholder id.
NEXT_PUBLIC_CSPR_CLICK_APP_ID=csprclick-template

# Contact email shown on the landing "request access" section.
# Optional — falls back to a maintainer address baked into the code.
NEXT_PUBLIC_ACCESS_EMAIL=you@example.com

# ---------------------------------------------------------------------------
# Server-only — read by Next.js API routes (src/app/api/**), never sent to
# the browser.
# ---------------------------------------------------------------------------

# CSPR.cloud API key used by /api/activity for per-wallet deploy history.
# Optional — if unset (here or inside AGENTS_ENV_FILE below), /api/activity
# just skips the on-chain history lookup gracefully.
CSPR_CLOUD_API_KEY=

# Path (relative to frontend/) to an env file containing CSPR_CLOUD_API_KEY,
# used as a fallback if the var above isn't set directly.
# Optional — defaults to ../agents/.env
AGENTS_ENV_FILE=../agents/.env

# Path (relative to frontend/) to the env file with signer keys, passed
# through to the Rust read/write bridge binaries (read_state, read_balance,
# kyc). Optional — defaults to ../.env
LIVENET_ENV_FILE=../.env

# Overrides for the compiled Rust bridge binary paths (relative to
# frontend/), used by /api/state, /api/balance, and /api/demo-kyc for live
# on-chain reads/writes. Optional — each defaults to
# ../target/release/{read_state,read_balance,kyc} (built via
# `cargo build --release -p sawit-deploy` from the repo root).
READ_STATE_BIN=../target/release/read_state
READ_BALANCE_BIN=../target/release/read_balance
KYC_BIN=../target/release/kyc
