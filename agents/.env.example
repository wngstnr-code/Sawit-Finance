# SAWIT.FI Agent Configuration
# Copy to .env and fill in your values

# Casper Testnet contract addresses (after deployment)
PRODUCTION_VAULT_CONTRACT=
YIELD_DISTRIBUTOR_CONTRACT=
SAWIT_TOKEN_CONTRACT=
TOKEN_MINTER_CONTRACT=

# Agent keypairs (Casper account secret keys in hex)
ORACLE_AGENT_SECRET_KEY=
YIELD_ROUTER_SECRET_KEY=
MARKET_ANALYST_SECRET_KEY=

# CSPR.cloud API key (get from cspr.cloud)
CSPR_CLOUD_API_KEY=

# x402 micropayments (Casper)
X402_LIVE=off                              # "on" = agents pay real x402 for gated data
X402_FACILITATOR_URL=http://127.0.0.1:8402 # run: python agents/x402_facilitator.py
X402_NETWORK=casper-test
X402_MAX_PRICE_MOTES=100000000             # 0.1 CSPR per-request ceiling

# Yield Router config
TRIGGER_MODE=monthly          # "monthly" or "price"
PRICE_TRIGGER_CENTS=85000     # $850/ton CPO trigger
MONTHLY_DISTRIBUTION_CSPR=5000
CHECK_INTERVAL_SECONDS=3600

# Gemini AI (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Market Analyst — closed-loop autonomy
ANALYSIS_INTERVAL_SECONDS=21600   # run analysis every 6h
AUTONOMY_MODE=off                 # "on" = agent applies GORR changes on-chain itself
MAX_GORR_CHANGE_BPS=100           # safety: max GORR change per cycle (bps)
MIN_GORR_BPS=100                  # safety: absolute GORR floor (1.0%)
MAX_GORR_BPS=1000                 # safety: absolute GORR ceiling (10.0%)
