# SAWIT.FI Agent Configuration
# Copy to .env and fill in your values

# Casper Testnet contract addresses (after deployment)
PRODUCTION_VAULT_CONTRACT=
YIELD_DISTRIBUTOR_CONTRACT=
SAWIT_TOKEN_CONTRACT=
TOKEN_MINTER_CONTRACT=

# Agent keypairs (Casper account secret keys in hex)
ORACLE_AGENT_SECRET_KEY=
YIELD_ROUTER_SECRET_KEY=
MARKET_ANALYST_SECRET_KEY=

# CSPR.cloud API key (get from cspr.cloud)
CSPR_CLOUD_API_KEY=

# x402 micropayments (Casper)
X402_LIVE=off                              # "on" = agents pay real x402 for gated data
X402_FACILITATOR_URL=http://127.0.0.1:8402 # run: python agents/x402_facilitator.py
X402_NETWORK=casper-test
X402_MAX_PRICE_MOTES=100000000             # 0.1 CSPR per-request ceiling

# Yield Router config
TRIGGER_MODE=monthly          # "monthly" or "price"
PRICE_TRIGGER_CENTS=85000     # $850/ton CPO trigger
MONTHLY_DISTRIBUTION_CSPR=5000
CHECK_INTERVAL_SECONDS=3600
EXTRA_HOLDERS=                # optional comma-separated account-hashes (manual supplementary holders)
VERIFY_BALANCES=0             # "1" = verify every holder's real on-chain SAWIT balance via read_balance
                               # (slow, ~minutes per account); "0" = use allocation-state estimates
AUTO_SWEEP=0                  # "1" = keeper sweeps expired unclaimed epochs on-chain (bin `sweep`)

# Gemini AI (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Market Analyst — closed-loop autonomy
ANALYSIS_INTERVAL_SECONDS=21600   # run analysis every 6h
AUTONOMY_MODE=off                 # "on" = agent applies GORR changes on-chain itself
MAX_GORR_CHANGE_BPS=100           # safety: max GORR change per cycle (bps)
MIN_GORR_BPS=100                  # safety: absolute GORR floor (1.0%)
MAX_GORR_BPS=1000                 # safety: absolute GORR ceiling (10.0%)
GORR_CHANGE_COOLDOWN_SECONDS=86400 # safety: min seconds between on-chain GORR changes
                                    # (persisted in agents/.market_state.json); a cycle
                                    # inside the cooldown still reports the recommendation
                                    # but skips the on-chain write
# Demo configuration (buildathon walkthrough): AUTONOMY_MODE=on

# Allocation Agent — processes Buy SAWIT deposits (memo 5417) into token allocations
TREASURY_ACCOUNT_HASH=e8134d5d5caf9ace626209d09365af48a867a18199b5139da8873733c6c14efe
SAWIT_PRICE_CSPR=10           # 1 SAWIT = 10 CSPR (must match frontend SALE.priceCspr)
BUY_MEMO_ID=5417              # transfer id tag for buy deposits (must match frontend)
SALE_EPOCH=                   # optional; if unset, derived from read_state epoch_count
ALLOCATE_BIN=                 # optional override; default target/release/allocate
ALLOCATION_INTERVAL_SECONDS=60
# Advisory LLM anomaly screening (uses GEMINI_API_KEY above if set, else the deterministic
# fallback below); flagged deposits are recorded with status "flagged" and NOT auto-allocated.
ALLOC_MAX_AUTO_CSPR=5000                 # deterministic fallback: flag any deposit above this
ALLOC_RAPID_REPEAT_WINDOW_SECONDS=600    # rapid-repeat-deposit detection window
ALLOC_RAPID_REPEAT_COUNT=3               # flag if N+ deposits from one sender within the window
