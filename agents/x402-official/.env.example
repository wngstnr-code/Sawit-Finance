# Optional — all values below are the working testnet defaults baked into env.ts.
# The only required input is a funded Casper testnet key, taken from the repo-root
# .env (ODRA_CASPER_LIVENET_SECRET_KEY_PATH) or overridden here:
# X402_SECRET_KEY_PATH=/path/to/secret_key.pem

# X402_NETWORK=casper:casper-test
# X402_RPC_URL=https://node.testnet.casper.network/rpc
# FACILITATOR_PORT=4022
# SERVER_PORT=4021

# Hosted CSPR.cloud Facilitator instead of the local one:
# FACILITATOR_URL=https://x402-facilitator.cspr.cloud
# FACILITATOR_API_KEY=<cspr.cloud access token>

# PAYEE_ADDRESS=00e8134d5d5caf9ace626209d09365af48a867a18199b5139da8873733c6c14efe
# ASSET_PACKAGE=ace00b4d5e5e1fb52be4260e0aba9cbf2595992eb599519d6b596b9ff0ea1f2b
# ASSET_NAME=SAWIT X402 Token
# ASSET_SYMBOL=SAWITX
# X402_PRICE_UNITS=1000000000
