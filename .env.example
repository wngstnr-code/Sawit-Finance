# SAWIT.FI — Casper livenet deployment config
# Copy to .env, then: cargo run -p sawit-deploy --bin deploy --features livenet

ODRA_BACKEND=casper
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# Path to the secret key generated by `casper-client keygen ./keys`
# The account must be funded: https://testnet.cspr.live/tools/faucet
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/secret_key.pem
